import turtle

# 1. Setup the physical window and the visual robot
window = turtle.Screen()
robot = turtle.Turtle(shape="turtle")
robot.speed(2)

# Set initial visual state to match your logic (facing North/Up)
robot.left(90) 

def solve_maze(steps):
    for i in range(steps):
        robot.forward(50)  # Physically drives the turtle forward
        
        if i % 3 == 0:
            robot.right(90)  # Physically turns the turtle right
            print(f"Step {i+1:2d}: Turned Right | Heading: {robot.heading()} degrees")
        elif i % 5 == 0:
            robot.left(90)   # Physically turns the turtle left
            print(f"Step {i+1:2d}: Turned Left  | Heading: {robot.heading()} degrees")
        else:
            print(f"Step {i+1:2d}: Went Straight | Heading: {robot.heading()} degrees")

# 2. Execute the visual navigation loop
solve_maze(20)

# Keep the graphics window open until you manually close it
window.mainloop()
