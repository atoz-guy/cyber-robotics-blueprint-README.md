# Maze-solving robot simulation
# (turtle graphics replaced with text output
#  since this playground runs on a server with no display)

import math

# Robot state
x, y = 0.0, 0.0
angle = 90  # facing up (North)

def forward(dist):
    global x, y
    rad = math.radians(angle)
    x += dist * math.cos(rad)
    y += dist * math.sin(rad)

def right(deg):
    global angle  # FIX: Crucial for Replit and standard Python environments
    angle = (angle - deg) % 360

def left(deg):
    global angle  # FIX: Crucial for Replit and standard Python environments
    angle = (angle + deg) % 360

def direction_name(a):
    names = {0: "East", 90: "North", 180: "West", 270: "South"}
    return names.get(a % 360, f"{a}deg")

def solve_maze(steps):
    global x, y, angle  # Safe practice for running in global iteration blocks
    for i in range(steps):
        forward(50)
        if i % 3 == 0:
            right(90)
            turn = "turned right"
        elif i % 5 == 0:
            left(90)
            turn = "turned left"
        else:
            turn = "went straight"
        print(f"Step {i+1:2d}: {turn:15s} | pos ({x:6.1f}, {y:6.1f}) | facing {direction_name(angle)}")

solve_maze(20)
print("\nDone! Robot finished navigating the maze.")
Use code with caution.
